# ─────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in real values.
# NEVER commit .env to Git (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────

# ── Zerodha Kite API ─────────────────────────────────────────────
ZERODHA_API_KEY=your_kite_api_key
ZERODHA_API_SECRET=your_kite_api_secret
# Generated daily via OAuth flow (python main.py token inside the container)
ZERODHA_ACCESS_TOKEN=
ZERODHA_REQUEST_TOKEN=

# ── Trading mode ─────────────────────────────────────────────────
# "simulation"  → paper trading (safe, no real money)
# "live"        → real orders via Zerodha Kite
TRADING_MODE=simulation

# ── SEBI static-IP whitelist ─────────────────────────────────────
# Comma-separated list of authorised IPs (leave blank to skip check)
# Your Lightsail static IP must be listed here when MODE=live
ALLOWED_IPS=

# ── SEBI Algo "license plate" tag (April 2026 mandate) ───────────
# Prepended to strategy name on every live order: e.g. STRAT_ma
# Register this prefix with Zerodha under your Kite app settings.
ALGO_ID_PREFIX=STRAT

# ── Simulation execution realism ──────────────────────────────────
# SIM_SLIPPAGE_PCT: bid-ask spread penalty on sim fills (default 0.05%)
# SIM_MPP_PCT:      SEBI Market Price Protection band (default 0.5%)
# These adjust the simulated fill price so SIM P&L matches LIVE reality.
# Only affects simulation — live fills are determined by the exchange.
SIM_SLIPPAGE_PCT=0.0005
SIM_MPP_PCT=0.005

# ── Data feed circuit breaker ─────────────────────────────────────
# In LIVE mode, if prices.json is older than this many seconds the
# tick is skipped and no orders are placed. SIM mode always continues.
PRICE_STALENESS_SECONDS=30

# ── GitHub storage ───────────────────────────────────────────────
# PAT with `repo` scope — Settings > Developer settings > Tokens (classic)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Private repo where trade_data/ will be committed (owner/repo)
GITHUB_REPO=your-github-username/trading-data
GITHUB_BRANCH=main

# ── Telegram notifications ───────────────────────────────────────
TG_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_CHAT_ID=123456789

# ── mTLS Security Alerts (mtls-watcher sidecar) ──────────────────
# Seconds before a second alert is sent for the same source IP.
# Prevents duplicate alerts from Streamlit's parallel sub-requests.
# Default: 60 (one alert per IP per minute)
DEDUP_WINDOW_SECONDS=60

# ── Docker Hub image ─────────────────────────────────────────────
# The image docker-compose will pull from Docker Hub
DOCKER_IMAGE=your-dockerhub-username/trading-bot:latest
